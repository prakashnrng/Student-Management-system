package com.studentportal.filter;

import java.io.IOException;

import jakarta.servlet.Filter;
import jakarta.servlet.FilterChain;
import jakarta.servlet.ServletException;
import jakarta.servlet.ServletRequest;
import jakarta.servlet.ServletResponse;
import jakarta.servlet.http.HttpServletRequest;
import jakarta.servlet.http.HttpServletResponse;
import jakarta.servlet.http.HttpSession;

public class StudentAuthFilter implements Filter{

	@Override
	public void doFilter(ServletRequest request, ServletResponse response, FilterChain chain)
			throws IOException, ServletException {
		System.out.println("-----------------------StudentAuthFilter-----------------------");
		

	 HttpServletRequest req=(HttpServletRequest)request;
	 HttpServletResponse res=(HttpServletResponse)response;
	 HttpSession ses=req.getSession(false);
	 System.out.println("StudentAuthFilter triggered  " + req.getRequestURI());
	 
	 
	 String path=req.getRequestURI();
	 boolean allowed=path.endsWith("login.jsp")||path.endsWith("StudentLoginServlet");
		if(allowed) {
			chain.doFilter(request, response);
			return;
		}
	 if(ses!=null) {
	 
		 String nm=(String)ses.getAttribute("NAME");
		 
		 //String id=(String)ses.getAttribute("SID");
		 Integer sid=(Integer)ses.getAttribute("SID");
		 //String bid=(String)ses.getAttribute("BID");
		 Integer bidd=(Integer)ses.getAttribute("BID");
		 || (nm!=null&&!nm.isEmpty()&&sid!=null && bidd!=null)
		
	 }else {
		 res.sendRedirect(req.getContextPath()+"/student/login.jsp");
	 }
	}
	

}

